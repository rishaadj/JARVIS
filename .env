# ============================================
# JARVIS Environment Configuration Template
# Copy this file to .env and fill in your values
# ============================================

# --- AI BRAINS (at least GEMINI_API_KEYS required) ---
# Get free keys at https://aistudio.google.com
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2

# Optional: Blazing-fast fallback. Get free key at https://console.groq.com
GROQ_API_KEY=your_groq_key1,your_groq_key2

# Optional: Models
OLLAMA_MODEL=llama3.2-vision
OLLAMA_UNCENSORED_MODEL=dolphin-llama3
GEMINI_MODEL=gemini-2.5-flash-lite

# --- EMAIL (optional) ---
EMAIL_USER=your_gmail@gmail.com
# HOW TO GET EMAIL_PASS:
# 1. Enable 2-Step Verification in your Google Account Security settings.
# 2. Search for "App Passwords" in your Google Account.
# 3. Create a new app named "JARVIS" and copy the 16-character code.
# 4. Paste it below WITHOUT spaces (e.g., abcdefghijklmnop).
EMAIL_PASS=your_gmail_app_password

# --- WHATSAPP via Twilio (optional — falls back to browser if not set) ---
# Sign up free at https://twilio.com
TWILIO_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+14155238886

# --- SECURITY ---
JARVIS_PIN=0000    # PIN to access the HUD remotely (change this!)

# --- AUTONOMY ---
JARVIS_ALLOW_DANGEROUS=true   # Set to false for confirmation prompts
